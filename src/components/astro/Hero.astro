---
---

<section class="hero" aria-labelledby="hero-heading">
    <div class="hero-bg-container" aria-hidden="true">
        <img
            src="/images/hero-bg.png"
            alt=""
            class="hero-img"
            loading="eager"
            fetchpriority="high"
            width="1440"
            height="810"
        />
    </div>

    <div class="container hero-content">
        <div class="hero-content-inner">
            <p class="text-base font-bold hero-badge">Purrfect Breeds</p>
            <h1 id="hero-heading" class="hero-title">
                Find the breed that matches your vibe.
            </h1>
            <p class="hero-subtitle">
                Sociis blandit et pellentesque aliquet at quisque tortor lacinia
                nullam. Mattis aenean scelerisque dui libero
            </p>
            <a href="#explore" class="btn btn--dark btn--lg"> Explore breeds</a>
        </div>
    </div>
</section>

<style>
    .hero {
        min-height: 58vh;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
        background-color: var(--color-surface-2);
    }

    .hero-bg-container {
        position: absolute;
        inset: 0;
        z-index: 1;
    }

    .hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
    }

    .hero-content {
        position: relative;
        z-index: 3;
    }

    .hero-content-inner {
        max-width: 600px;
        padding: 10rem 0 5rem;
    }

    .hero-badge {
        color: #ffffff;
        margin-bottom: var(--space-6);
    }

    .hero-title {
        font-size: var(--text-3xl);
        font-weight: var(--weight-bold);
        line-height: var(--leading-tight);
        color: var(--color-accent);
        margin-bottom: var(--space-6);
    }

    .hero-subtitle {
        font-family: var(--font-secondary);
        font-size: var(--text-base);
        color: var(--color-accent-dim);
        margin-bottom: var(--space-12);
        line-height: var(--leading-normal);
    }
</style>
