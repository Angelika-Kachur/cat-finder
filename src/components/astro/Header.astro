---
---

<header class="header" role="banner">
    <div class="container">
        <div class="header__inner">
            <a href="/" class="logo" aria-label="Purrfect Breeds — Home">
                <img
                    src="/images/logo.svg"
                    alt=""
                    class="logo-img"
                    width="140"
                    height="38"
                />
            </a>

            <nav class="nav" aria-label="Main navigation">
                <ul class="nav-list">
                    <li>
                        <a
                            href="/"
                            class="nav-link nav-link--active"
                            aria-current="page">Home</a
                        >
                    </li>
                    <li>
                        <a href="/about-us" class="nav-link">About Us</a>
                    </li>
                    <li>
                        <a href="/contact" class="nav-link">Contact</a>
                    </li>
                </ul>
            </nav>

            <div class="header__actions">
                <form
                    class="search-bar"
                    role="search"
                    aria-label="Site search"
                    onsubmit="return false;"
                >
                    <label for="header-search" class="sr-only"
                        >Search products</label
                    >
                    <input
                        type="search"
                        id="header-search"
                        placeholder="Search products..."
                        class="search-input"
                        autocomplete="off"
                    />
                    <button
                        type="submit"
                        class="search-btn"
                        aria-label="Submit search"
                    >
                        <svg
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                        >
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                    </button>
                </form>

                <button class="favorites-btn" aria-label="Favorites (0 items)">
                    <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path
                            d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                        ></path>
                    </svg>
                    <span class="favorites-badge" aria-hidden="true">0</span>
                </button>

                <button
                    class="burger"
                    id="burger-btn"
                    aria-label="Open menu"
                    aria-expanded="false"
                    aria-controls="mobile-drawer"
                >
                    <span class="burger__line" aria-hidden="true"></span>
                    <span class="burger__line" aria-hidden="true"></span>
                    <span class="burger__line" aria-hidden="true"></span>
                </button>
            </div>
        </div>
    </div>
</header>

<div class="mobile-overlay" id="mobile-overlay" aria-hidden="true"></div>

<aside
    class="mobile-drawer"
    id="mobile-drawer"
    role="dialog"
    aria-label="Mobile navigation"
    aria-modal="true"
    aria-hidden="true"
>
    <div class="mobile-drawer__header">
        <a href="/" aria-label="Purrfect Breeds — Home">
            <img
                src="/images/logo.svg"
                alt=""
                class="logo-img"
                width="140"
                height="38"
            />
        </a>
        <button
            class="mobile-drawer__close"
            id="drawer-close"
            aria-label="Close menu"
        >
            <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>
    <nav aria-label="Mobile navigation">
        <ul class="mobile-drawer__nav-list">
            <li>
                <a href="/" class="nav-link--active" aria-current="page">Home</a
                >
            </li>
            <li><a href="/about-us">About Us</a></li>
            <li><a href="/contact">Contact</a></li>
        </ul>
    </nav>
    <div class="mobile-drawer__favorites">
        <button class="favorites-btn" aria-label="Favorites (0 items)">
            <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <path
                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                ></path>
            </svg>
            <span class="favorites-badge" aria-hidden="true">0</span>
        </button>
        <span class="mobile-drawer__favorites-label">Favorites</span>
    </div>
</aside>

<script>
    const burger = document.getElementById("burger-btn") as HTMLButtonElement;
    const overlay = document.getElementById("mobile-overlay") as HTMLDivElement;
    const drawer = document.getElementById("mobile-drawer") as HTMLElement;
    const closeBtn = document.getElementById(
        "drawer-close"
    ) as HTMLButtonElement;

    function openMenu(): void {
        drawer.classList.add("is-open");
        drawer.setAttribute("aria-hidden", "false");
        overlay.classList.add("is-open");
        burger.setAttribute("aria-expanded", "true");
        burger.setAttribute("aria-label", "Close menu");
        document.body.style.overflow = "hidden";
        closeBtn.focus();
    }

    function closeMenu(): void {
        drawer.classList.remove("is-open");
        drawer.setAttribute("aria-hidden", "true");
        overlay.classList.remove("is-open");
        burger.setAttribute("aria-expanded", "false");
        burger.setAttribute("aria-label", "Open menu");
        document.body.style.overflow = "";
        burger.focus();
    }

    burger.addEventListener("click", () => {
        const isOpen = drawer.classList.contains("is-open");
        isOpen ? closeMenu() : openMenu();
    });

    closeBtn.addEventListener("click", closeMenu);
    overlay.addEventListener("click", closeMenu);

    document.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Escape" && drawer.classList.contains("is-open")) {
            closeMenu();
        }
    });

    // Sticky header on scroll
    const header = document.querySelector(".header") as HTMLElement;
    const stickyThreshold = header.offsetTop + header.offsetHeight;

    function handleScroll(): void {
        if (window.scrollY > stickyThreshold) {
            header.classList.add("is-sticky");
        } else {
            header.classList.remove("is-sticky");
        }
    }

    window.addEventListener("scroll", handleScroll, { passive: true });
</script>

<style>
    .header {
        position: absolute;
        top: var(--space-6);
        left: 0;
        right: 0;
        z-index: 100;
        width: 100%;
        transition: top var(--duration-base) var(--ease-out),
            box-shadow var(--duration-base) var(--ease-out);
    }

    .header .container {
        max-width: var(--max-width-2xl);
    }

    .header.is-sticky {
        position: fixed;
        top: 0;
        padding-top: var(--space-2);
        padding-bottom: var(--space-2);
        background: var(--color-bg);
        box-shadow: var(--shadow-md);
        animation: slideDown var(--duration-base) var(--ease-out);
    }

    @keyframes slideDown {
        from {
            transform: translateY(-100%);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .header__inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--color-bg);
        border-radius: var(--radius-full);
        padding: var(--space-3) var(--space-8);
        box-shadow: var(--shadow-md);
        transition: box-shadow var(--duration-base) var(--ease-out);
    }

    .header.is-sticky .header__inner {
        box-shadow: none;
    }

    .logo {
        display: flex;
        align-items: center;
    }

    .logo-img {
        height: 38px;
        display: block;
    }

    .nav-list {
        display: flex;
        gap: var(--space-8);
        align-items: center;
        font-size: var(--text-lg);
        font-weight: var(--weight-bold);
        color: var(--color-text);
    }

    .nav-link {
        transition: color var(--duration-fast) var(--ease-out);
    }

    .nav-link:hover {
        color: var(--color-primary);
    }

    .nav-link--active {
        color: var(--color-primary);
        border-bottom: 2px solid var(--color-primary);
        padding-bottom: var(--space-1);
    }

    .header__actions {
        display: flex;
        align-items: center;
        gap: var(--space-6);
    }

    /* ── Search ──────────────────────────────────────────────── */
    .search-bar {
        position: relative;
        display: flex;
        align-items: center;
    }

    .search-input {
        padding: var(--space-2) var(--space-10) var(--space-2) var(--space-5);
        border-radius: var(--radius-full);
        border: none;
        background: var(--color-surface-2);
        font-size: var(--text-sm);
        outline: none;
        width: 220px;
        transition: width var(--duration-fast) var(--ease-out);
    }

    .search-btn {
        position: absolute;
        right: var(--space-1);
        background: var(--color-accent);
        color: var(--color-bg);
        width: 26px;
        height: 26px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: var(--text-xs);
        border: none;
        cursor: pointer;
        transition: transform var(--duration-fast) var(--ease-out);
    }

    .search-btn:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
        transform: scale(1.1);
    }

    /* ── Favorites ───────────────────────────────────────────── */
    .favorites-btn {
        position: relative;
        cursor: pointer;
        color: var(--color-text);
        display: flex;
        align-items: center;
    }

    .favorites-badge {
        position: absolute;
        top: -4px;
        right: -6px;
        background: var(--color-primary);
        color: var(--color-bg);
        font-size: var(--text-xs);
        font-weight: var(--weight-bold);
        width: var(--space-4);
        height: var(--space-4);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* ── Burger button ───────────────────────────────────────── */
    .burger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: var(--space-8);
        height: var(--space-8);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
    }

    .burger__line {
        display: block;
        width: 100%;
        height: 2.5px;
        background: var(--color-primary-2);
        border-radius: var(--radius-sm);
        transition: transform var(--duration-base) var(--ease-out),
            opacity var(--duration-base) var(--ease-out);
    }

    /* ── Mobile overlay ──────────────────────────────────────── */
    .mobile-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        z-index: 199;
        opacity: 0;
        pointer-events: none;
        transition: opacity var(--duration-base) var(--ease-out);
    }

    .mobile-overlay.is-open {
        opacity: 1;
        pointer-events: auto;
    }

    /* ── Mobile drawer ───────────────────────────────────────── */
    .mobile-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: 300px;
        max-width: 85vw;
        height: 100vh;
        background: var(--color-bg);
        z-index: 200;
        transform: translateX(100%);
        transition: transform var(--duration-base) var(--ease-out);
        display: flex;
        flex-direction: column;
        padding: var(--space-6);
    }

    .mobile-drawer.is-open {
        transform: translateX(0);
    }

    .mobile-drawer__header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-10);
    }

    .mobile-drawer__close {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--color-text);
        padding: var(--space-1);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .mobile-drawer__nav-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .mobile-drawer__nav-list a {
        font-size: var(--text-lg);
        font-weight: var(--weight-bold);
        color: var(--color-text);
        text-decoration: none;
        transition: color var(--duration-fast) var(--ease-out);
    }

    .mobile-drawer__nav-list a:hover {
        color: var(--color-primary);
    }

    .mobile-drawer__nav-list .nav-link--active {
        color: var(--color-primary);
        border-bottom: none;
        padding-bottom: 0;
    }

    /* ── Drawer favorites ────────────────────────────────────── */
    .mobile-drawer__favorites {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        margin-top: var(--space-8);
        padding-top: var(--space-8);
        border-top: 1px solid var(--color-border);
    }

    .mobile-drawer__favorites-label {
        font-size: var(--text-base);
        font-weight: var(--weight-semibold);
        color: var(--color-text);
    }

    /* ── Mobile-first: nav, search, favorites hidden by default ── */
    .nav {
        display: none;
    }

    .search-bar {
        display: none;
    }

    .header__actions > .favorites-btn {
        display: none;
    }

    .burger {
        display: flex;
    }

    /* ── Desktop (lg+): show nav, hide burger & drawer ────────── */
    @media (min-width: 1025px) {
        .nav {
            display: block;
        }

        .search-bar {
            display: flex;
        }

        .header__actions > .favorites-btn {
            display: flex;
        }

        .burger {
            display: none;
        }

        .mobile-overlay,
        .mobile-drawer {
            display: none !important;
        }

        .header__inner {
            padding: var(--space-5) var(--space-8);
        }
    }
</style>
